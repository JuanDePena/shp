{
  "name": "simplehost-panel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "bootstrap": "pnpm install",
    "build": "pnpm -r --if-present build",
    "start:api": "pnpm build && node apps/api/dist/index.js",
    "start:web": "pnpm build && node apps/web/dist/index.js",
    "start:worker": "pnpm build && node apps/worker/dist/index.js",
    "typecheck": "pnpm -r --if-present typecheck",
    "clean": "pnpm -r --if-present clean",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3"
  }
}
