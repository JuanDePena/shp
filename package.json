{
  "name": "simplehost-panel",
  "version": "2603.14.00",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "bootstrap": "pnpm install",
    "build": "pnpm --filter @simplehost/panel-contracts build && pnpm --filter @simplehost/panel-config build && pnpm --filter @simplehost/panel-ui build && pnpm --filter @simplehost/panel-testing build && pnpm --filter @simplehost/panel-database build && pnpm --filter @simplehost/panel-api build && pnpm --filter @simplehost/panel-worker build && pnpm --filter @simplehost/panel-web build",
    "db:migrate": "pnpm --filter @simplehost/panel-database build && node packages/database/dist/migrate-cli.js",
    "bundle:release": "./scripts/build-release-bundle.sh",
    "install:bundle": "./scripts/install-bundle.sh",
    "release:rollback": "./scripts/rollback-release.sh",
    "version:set": "node scripts/set-version.mjs",
    "version:today": "node scripts/set-version.mjs --today",
    "start:api": "pnpm build && node apps/api/dist/index.js",
    "start:web": "pnpm build && node apps/web/dist/index.js",
    "start:worker": "pnpm build && node apps/worker/dist/index.js",
    "typecheck": "pnpm -r --if-present typecheck",
    "clean": "pnpm -r --if-present clean",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/pg": "^8.18.0",
    "typescript": "^5.8.3"
  }
}
